# =============================================
# INNOVÉA — AAP MedTech Veille
# Variables d'environnement
# =============================================
# Copier ce fichier en .env.local pour le développement local.
# Sur Vercel : ajouter ces variables dans Settings → Environment Variables.

# ------ Auth admin ------
# Mot de passe de l'interface admin (choisir une chaîne longue et aléatoire)
ADMIN_SECRET=change-me-to-a-strong-secret

# ------ Email (Resend) ------
# Créer un compte sur https://resend.com (gratuit jusqu'à 3 000 emails/mois)
# Ajouter votre domaine, puis copier la clé API
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Adresses de destination du digest mensuel (séparées par des virgules)
NOTIFY_EMAILS=sam@shs-france.com,colleague@shs-france.com

# ------ Cron auth ------
# Secret partagé entre GitHub Actions et l'API /notify
# Générer avec : openssl rand -hex 32
CRON_SECRET=change-me-to-another-strong-secret
